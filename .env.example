# Your Jira Cloud site, no trailing slash
JIRA_BASE_URL=https://your-site.atlassian.net

# The account whose token this is (usually a service/bot account)
JIRA_EMAIL=you@example.com

# Paste the API token you create at id.atlassian.com (see README)
JIRA_API_TOKEN=your-jira-api-token-here

# Scoped to a project key. Leave blank to include all projects.
JIRA_PROJECT_KEY=DAA

# Optional: override the "completed since" window in days.
# Leave blank to auto-use 3 days on Mondays and 1 day otherwise.
STANDUP_LOOKBACK_DAYS=

PORT=3000
